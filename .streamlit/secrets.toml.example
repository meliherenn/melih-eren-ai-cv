# Copy this file to `.streamlit/secrets.toml` locally.
# On Streamlit Community Cloud, add the same values under App settings > Secrets.

# Default provider. Supported presets: cerebras, groq, gemini.
LLM_PROVIDER = "cerebras"

# Cerebras production default in app.py. Override when needed.
LLM_MODEL = "gpt-oss-120b"
CEREBRAS_API_KEY = "replace-with-your-cerebras-key"

# Optional admin panel password. Use a long random value.
ADMIN_PASSWORD = "replace-with-a-strong-password"

# Optional generic OpenAI-compatible override:
# LLM_BASE_URL = "https://api.cerebras.ai/v1"
# LLM_API_KEY = "replace-with-provider-key"
